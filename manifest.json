{
  "manifest_version": 3,
  "name": "Kampus Auto Login",
  "version": "2.0",
  "description": "Automate the repetitive login process for Sanoma Pro Kampus.",
  "minimum_chrome_version": "120",
  "permissions": [
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://kirjautuminen.sanomapro.fi/*",
    "https://mpass-proxy.csc.fi/*",
    "https://sanomapro.fi/*",
    "https://www.sanomapro.fi/*"
  ],
  "optional_host_permissions": [
    "https://*/adfs/ls/*"
  ],
  "action": {
    "default_popup": "ui/popup.html",
    "default_title": "Kampus Auto Login",
    "default_icon": {
      "32": "ui/icons/icon32.png",
      "48": "ui/icons/icon48.png",
      "64": "ui/icons/icon64.png"
    }
  },
  "icons": {
    "32": "ui/icons/icon32.png",
    "48": "ui/icons/icon48.png",
    "64": "ui/icons/icon64.png",
    "96": "ui/icons/icon96.png",
    "128": "ui/icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "options_ui": {
    "page": "ui/setup.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": [
        "https://kirjautuminen.sanomapro.fi/*"
      ],
      "js": [
        "ui/i18n.js",
        "scripts/content-common.js",
        "scripts/kirjautuminen-content.js"
      ],
      "run_at": "document_end"
    },
    {
      "matches": [
        "https://mpass-proxy.csc.fi/*"
      ],
      "js": [
        "ui/i18n.js",
        "scripts/content-common.js",
        "scripts/mpass-content.js"
      ],
      "run_at": "document_end"
    },
    {
      "matches": [
        "https://sanomapro.fi/*",
        "https://www.sanomapro.fi/*"
      ],
      "js": [
        "ui/i18n.js",
        "scripts/content-common.js",
        "scripts/sanomapro-content.js"
      ],
      "run_at": "document_end"
    }
  ]
}
