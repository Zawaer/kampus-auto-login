{
  "host_permissions": [
    "https://kirjautuminen.sanomapro.fi/*",
    "https://mpass-proxy.csc.fi/*",
    "https://sanomapro.fi/*",
    "https://www.sanomapro.fi/*",
    "https://*/adfs/ls/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://kirjautuminen.sanomapro.fi/*"
      ],
      "js": [
        "scripts/kirjautuminen-content.js"
      ],
      "run_at": "document_end"
    },
    {
      "matches": [
        "https://mpass-proxy.csc.fi/*"
      ],
      "js": [
        "scripts/mpass-content.js"
      ],
      "run_at": "document_end"
    },
    {
      "matches": [
        "https://sanomapro.fi/*",
        "https://www.sanomapro.fi/*"
      ],
      "js": [
        "scripts/sanomapro-content.js"
      ],
      "run_at": "document_end"
    },
    {
      "matches": [
        "https://*/adfs/ls/*"
      ],
      "js": [
        "scripts/adfs-content.js"
      ],
      "run_at": "document_end"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "@sanomapro-kampus-auto-login",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  }
}
